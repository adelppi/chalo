{
  "expo": {
    "name": "chalo",
    "slug": "chalo",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "chalo",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F1EADA",
    "platforms": [
      "ios"
    ],
    "ios": {
      "bundleIdentifier": "com.adelppi.chalo",
      "usesAppleSignIn": true,
      "icon": "./src/assets/icon/chalo.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F1EADA",
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-apple-authentication",
      "expo-notifications",
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      [
        "expo-calendar",
        {
          "calendarPermission": "プランを端末のカレンダーに追加・更新するために使います。",
          "remindersPermission": false
        }
      ],
      "expo-sharing",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b369ede-5850-4729-94d8-9117b3f12638"
      }
    },
    "owner": "adelppi"
  }
}
