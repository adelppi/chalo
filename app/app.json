{
  "expo": {
    "name": "chalo",
    "slug": "chalo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "chalo",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ffffff",
    "platforms": ["ios"],
    "ios": {
      "bundleIdentifier": "com.adelppi.chalo"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
