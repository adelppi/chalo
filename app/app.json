{
  "expo": {
    "name": "chalo",
    "slug": "chalo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "chalo",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ffffff",
    "platforms": ["ios"],
    "ios": {
      "bundleIdentifier": "com.adelppi.chalo",
      "usesAppleSignIn": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b369ede-5850-4729-94d8-9117b3f12638"
      }
    },
    "owner": "adelppi"
  }
}
